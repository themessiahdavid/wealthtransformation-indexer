{
  "name": "wealthtransformation-indexer",
  "version": "1.0.0",
  "description": "On-chain indexer that watches Base for WT Purchased events and forwards them to IAT via HMAC-signed webhook.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "dotenv": "^17.4.2",
    "viem": "^2.48.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
